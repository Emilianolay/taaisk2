// --- 1. CONFIGURACIÓN DE PRISMA Y BASE DE DATOS ---
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- 2. TABLA DE USUARIOS ---
model User {
  id                  String   @id @default(uuid())
  name                String?
  email               String   @unique
  password            String
  currentStreak       Int      @default(0)
  bestStreak          Int      @default(0)
  tasksCompletedTotal Int      @default(0)
  createdAt           DateTime @default(now())
  
  // Relación: Un usuario puede tener muchas tareas
  tasks               Task[]
}

// --- 3. OPCIONES PARA LAS TAREAS ---
enum TaskStatus {
  TODO
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

// --- 4. TABLA DE TAREAS DETALLADA ---
model Task {
  id          String       @id @default(uuid())
  title       String
  description String?      
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(LOW)
  dueDate     DateTime?    
  fileUrl     String?      
  tags        String[]     
  position    Int          @default(0)
  
  // Relación: Esta tarea pertenece a un usuario específico
  userId      String
  user        User         @relation(fields: [userId], references: [id])
  createdAt   DateTime     @default(now())
}